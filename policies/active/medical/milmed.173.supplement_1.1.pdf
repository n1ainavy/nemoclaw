                    <h2 scrollto-destination=99845917 id="99845917" class="abstract-title js-splitscreen-abstract-title" >ABSTRACT</h2>
<section class="abstract" aria-label="Main abstract"><p class="chapter-para">The Department of Defense has an oral health and readiness classification system, which is designed to standardize the dental readiness (deployability), assess oral health, prioritize dental care, and minimize the occurrence of dental emergencies among military personnel. This classification system is a critical component of the individual medical readiness assessment of military personnel and emphasizes the importance of good oral health.</p></section>                    <div class="article-metadata-panel clearfix at-ArticleMetadata"></div>
    <!-- /foreach in Model.Sections -->
    <div class="widget widget-ArticlePubStateInfo widget-instance-OUP_ArticlePubStateInfo">
         
    </div>



        <div class="article-metadata-standalone-panel clearfix"></div>

        
<div class="copyright copyright-statement">Reprint &amp; Copyright © Association of Military Surgeons of the U.S.</div><!-- /foreach -->

        <span id="UserHasAccess" data-userHasAccess="False"></span>

    </div><!-- /.widget-items -->
</div><!-- /.module-widget -->





 
